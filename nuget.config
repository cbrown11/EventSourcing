<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="github-cbrown11" value="https://nuget.pkg.github.com/cbrown11/index.json" />
  </packageSources>
  <!-- GPR-only packages (Cbrown11.*, DomainDrivenDesign). Requires PAT on github-cbrown11. -->
  <packageSourceMapping>
    <packageSource key="github-cbrown11">
      <package pattern="*" />
      <package pattern="DomainDrivenDesign" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
